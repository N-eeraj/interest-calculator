{
  "name": "@app/definitions",
  "version": "1.0.0",
  "description": "Shared enums and constants",
  "type": "module",
  "imports": {
    "#enums/*": "./src/enums/*.ts",
    "#constants/*": "./src/constants/*.ts"
  },
  "exports": {
    "./*": "./src/*.ts",
    "./enums/*": "./src/enums/*.ts",
    "./constants/*": "./src/constants/*.ts"
  }
}
