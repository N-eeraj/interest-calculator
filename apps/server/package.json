  "type": "module",
  "scripts": {
    "dev": "node --watch --env-file=.env --import tsx src/server/index.ts",
    "db:generate": "npx drizzle-kit generate  --name \"$(date +%s)_$npm_config_name\"",
    "db:migrate": "npx drizzle-kit migrate"
  },
  "imports": {
    "#src/*": "./src/*.ts",
    "#server/*": "./src/server/*.ts",
    "#middlewares/*": "./src/middlewares/*.ts",
    "#app/*": "./src/app/*.ts",
    "#procedures/*": "./src/app/procedures/*.ts",
    "#db/*": "./src/db/*.ts"
  },
  "devDependencies": {
    "@types/bcrypt": "^6.0.0",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^22.19.13",
    "drizzle-kit": "^0.31.9",
    "tsx": "^4.21.0"
  },
  "dependencies": {
    "bcrypt": "^6.0.0",
    "cors": "^2.8.6",
    "drizzle-orm": "^0.45.1",
    "express": "^5.2.1",
    "mysql2": "^3.19.1"
  }
}
